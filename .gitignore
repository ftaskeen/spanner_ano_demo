# Local .terraform directory
**/.terraform/*

# .tfstate files
*.tfstate
*.tfstate.*

# Crash log files
crash.log
crash.*.log

# Exclude override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Include plugin cache directory
.terraform/plugin-cache/*

# Ignore CLI configuration files
.terraformrc
terraform.rc
